---
import BaseLayout from './BaseLayout.astro';
import DevSwitcher from '../components/DevSwitcher.astro';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es';
}

const { title, description, lang } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} bodyClass="font-body bg-surface-100 text-surface-900 dark:bg-terminal-bg dark:text-terminal-fg min-h-screen selection:bg-primary-500/20 selection:text-primary-400">
  <Fragment slot="fonts">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  </Fragment>

  <Fragment slot="theme-color">
    <meta name="theme-color" content="#f0f0f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0f" media="(prefers-color-scheme: dark)" />
  </Fragment>

  <!-- Scanline overlay — thin horizontal lines for CRT feel -->
  <div slot="overlay" class="pointer-events-none fixed inset-0 z-50 opacity-[0.03] dark:opacity-[0.08]" aria-hidden="true">
    <div class="absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_3px,rgba(0,0,0,0.15)_3px,rgba(0,0,0,0.15)_4px)]"></div>
  </div>

  <slot />

  <button
    slot="scroll-top"
    id="scroll-top"
    class="fixed bottom-6 right-6 z-40 w-11 h-11 rounded-full bg-primary-600/80 dark:bg-primary-600/30 border border-primary-400/50 dark:border-primary-400/60 text-surface-50 dark:text-primary-300 shadow-[0_0_15px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] dark:shadow-[0_0_20px_color-mix(in_srgb,var(--color-primary-500)_45%,transparent)] backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 hover:shadow-[0_0_25px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)] dark:hover:shadow-[0_0_35px_color-mix(in_srgb,var(--color-primary-500)_65%,transparent)] hover:bg-primary-500 dark:hover:bg-primary-600/50 flex items-center justify-center"
    aria-label={lang === 'en' ? 'Scroll to top' : 'Ir arriba'}
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <DevSwitcher slot="dev-switcher" lang={lang} currentDesign="neon" />
</BaseLayout>

<style is:global>
  body {
    font-family: 'IBM Plex Sans', sans-serif;
  }
  .font-display {
    font-family: 'Space Grotesk', sans-serif;
  }
</style>
