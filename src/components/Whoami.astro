---
import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="flex flex-col md:flex-row gap-6 lg:gap-12 items-start mt-4">
  <!-- Avatar / ASCII Art area -->
  <div class="w-full md:w-1/3 flex-shrink-0">
    <div class="border border-surface-200 dark:border-terminal-border p-2 inline-block bg-surface-100 dark:bg-terminal-bg shadow-sm">
      <img src={profile.avatar} alt={profile.name} width="200" height="200" decoding="async" class="w-full max-w-[200px] md:max-w-full h-auto filter grayscale hover:grayscale-0 transition-all duration-500" />
    </div>
    
    <div class="mt-6 font-bold text-sm text-surface-600 dark:text-surface-400">
      <div class="mb-2">
        <span class="text-primary-600 dark:text-primary-400">OS:</span> Android SDK, Kotlin
      </div>
      <div class="mb-2">
        <span class="text-primary-600 dark:text-primary-400">Location:</span> {profile.location}
      </div>
      <div class="mb-2">
        <span class="text-primary-600 dark:text-primary-400">Status:</span> {profile.badge[lang]}
      </div>
      <div class="mb-2">
        <span class="text-primary-600 dark:text-primary-400">{lang === 'es' ? 'Intereses:' : 'Hobbies:'}</span> {profile.hobbies[lang].join(', ')}
      </div>
    </div>
  </div>
  
  <!-- Content area -->
  <div class="w-full md:w-2/3">
    <h1 class="text-2xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-primary-300 dark:animate-glow mb-2">
      {profile.name}
    </h1>
    <h2 class="text-xl sm:text-2xl text-primary-600 dark:text-accent-400 mb-6 font-bold">
      {profile.headline[lang]}
    </h2>
    
    <div class="text-surface-700 dark:text-surface-300 space-y-4 mb-8 text-sm sm:text-base leading-relaxed border-l-2 border-surface-200 dark:border-terminal-dim pl-4">
      <p class="font-bold text-surface-900 dark:text-surface-100">"{profile.subheadline[lang]}"</p>
      <p>{profile.heroDescription[lang]}</p>
    </div>
    
    <div class="flex flex-wrap gap-4 mt-6">
      <a href="#contact" class="inline-block bg-primary-600 dark:bg-primary-700 hover:bg-primary-700 dark:hover:bg-primary-600 text-white font-bold py-2 px-6 border border-primary-700 dark:border-primary-500 rounded-sm transition-colors">
        {t('hero.cta.contact')}
      </a>
      <a href="#projects" class="inline-block bg-surface-200 dark:bg-transparent hover:bg-surface-300 dark:hover:bg-terminal-border text-surface-800 dark:text-primary-400 font-bold py-2 px-6 border border-surface-300 dark:border-primary-700 rounded-sm transition-colors">
        {t('hero.cta.projects')}
      </a>
    </div>
  </div>
</div>
