---
import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="mt-4 font-mono text-sm sm:text-base grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
  {Object.entries(profile.skills).map(([category, skills]) => (
    <div class="border border-surface-200 dark:border-terminal-border bg-surface-100 dark:bg-[#0a0f0d] p-4 shadow-sm group hover:border-primary-500 dark:hover:border-primary-600 transition-colors">
      <div class="mb-4 text-surface-500 dark:text-surface-400 font-bold border-b border-surface-300 dark:border-terminal-dim pb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
        drwxr-xr-x {category}
      </div>
      <ul class="space-y-2">
        {skills.map(skill => (
          <li class="flex items-center group/item">
            <span class="text-surface-400 dark:text-surface-400 mr-2 group-hover/item:text-primary-500 dark:group-hover/item:text-accent-400 transition-colors">-rw-r--r--</span>
            <span class="text-surface-800 dark:text-surface-300 font-medium group-hover/item:text-primary-700 dark:group-hover/item:text-white transition-colors">
              {skill}
            </span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
