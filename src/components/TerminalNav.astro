---
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangUrl = lang === 'en' ? '/es/' : '/';
---

<nav class="mb-8 w-full border-b-2 border-surface-200 dark:border-terminal-border pb-4 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
  <div class="flex gap-4 sm:gap-6 font-bold text-sm sm:text-base flex-wrap">
    <a href={`#about`} class="text-surface-600 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-400 transition-colors">
      <span class="text-surface-400 dark:text-surface-400">./</span>{t('nav.about')}
    </a>
    <a href={`#experience`} class="text-surface-600 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-400 transition-colors">
      <span class="text-surface-400 dark:text-surface-400">./</span>{t('nav.experience')}
    </a>
    <a href={`#projects`} class="text-surface-600 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-400 transition-colors">
      <span class="text-surface-400 dark:text-surface-400">./</span>{t('nav.projects')}
    </a>
    <a href={`#skills`} class="text-surface-600 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-400 transition-colors">
      <span class="text-surface-400 dark:text-surface-400">./</span>{t('nav.skills')}
    </a>
  </div>
  
  <div class="flex gap-4 font-bold text-sm">
    <button id="theme-toggle" class="group flex items-center gap-2 px-2 py-1 rounded hover:bg-surface-200 dark:hover:bg-surface-800 transition-colors">
      <span class="text-surface-500 dark:text-surface-400">$</span> 
      <span class="text-surface-700 dark:text-primary-500 group-hover:underline">theme</span>
    </button>
    <a href={otherLangUrl} class="group flex items-center gap-2 px-2 py-1 rounded hover:bg-surface-200 dark:hover:bg-surface-800 transition-colors">
      <span class="text-surface-500 dark:text-surface-400">$</span> 
      <span class="text-surface-700 dark:text-primary-500 group-hover:underline">locales/{otherLang}</span>
    </a>
  </div>
</nav>
