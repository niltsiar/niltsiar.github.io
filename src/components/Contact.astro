---
import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="mt-4 font-mono text-sm sm:text-base p-4 border border-surface-200 dark:border-terminal-border bg-surface-100 dark:bg-terminal-bg shadow-sm flex flex-col items-start gap-4">
  <div class="w-full text-surface-600 dark:text-surface-400 font-bold mb-4 border-b border-surface-300 dark:border-terminal-dim pb-2">
    #!/bin/bash
    <br/>
    # {t('contact.title')}
  </div>
  
  <div class="flex items-center gap-4 group w-full p-3 min-h-[44px] hover:bg-surface-100 dark:hover:bg-terminal-hover transition-colors rounded relative">
    <span class="text-primary-600 dark:text-accent-500 font-bold">$ open</span>
    <a href={`mailto:${profile.email}`} aria-label={lang === 'en' ? 'Send email' : 'Enviar email'} class="text-surface-800 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">{profile.email}</a>
    <button data-copy={profile.email} aria-label={lang === 'en' ? 'Copy email' : 'Copiar email'} class="copy-btn ml-auto text-surface-400 hover:text-primary-600 dark:hover:text-accent-400 transition-colors opacity-0 group-hover:opacity-100 min-w-[44px] min-h-[44px] flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
    </button>
  </div>
  
  <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex items-center gap-4 group w-full p-3 min-h-[44px] hover:bg-surface-100 dark:hover:bg-terminal-hover transition-colors rounded">
    <span class="text-primary-600 dark:text-accent-500 font-bold">$ open</span>
    <span class="text-surface-800 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">linkedin.com/in/bquepab</span>
  </a>
  
  <a href={profile.github.url} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="flex items-center gap-4 group w-full p-3 min-h-[44px] hover:bg-surface-100 dark:hover:bg-terminal-hover transition-colors rounded">
    <span class="text-primary-600 dark:text-accent-500 font-bold">$ open</span>
    <span class="text-surface-800 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">github.com/niltsiar</span>
  </a>
  
  <a href={profile.mastodon} target="_blank" rel="noopener noreferrer" aria-label="Mastodon" class="flex items-center gap-4 group w-full p-3 min-h-[44px] hover:bg-surface-100 dark:hover:bg-terminal-hover transition-colors rounded">
    <span class="text-primary-600 dark:text-accent-500 font-bold">$ open</span>
    <span class="text-surface-800 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">androiddev.social/@niltsiar</span>
  </a>
</div>
