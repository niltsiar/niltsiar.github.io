---
interface Props {
  title?: string;
  id?: string;
}

const { title = 'bash', id } = Astro.props;
---

<div class="max-w-4xl mx-auto w-full mb-12 shadow-2xl rounded-lg overflow-hidden border border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-terminal-bg" {id}>
  <!-- Window Chrome -->
  <div class="bg-surface-200 dark:bg-terminal-header px-4 py-2 flex items-center justify-between border-b border-surface-300 dark:border-terminal-chrome">
    <div class="flex space-x-2 group/chrome">
      <div class="w-3 h-3 rounded-full bg-[#ff5f56] transition-transform duration-200 group-hover/chrome:scale-125 group-hover/chrome:shadow-[0_0_6px_#ff5f56]"></div>
      <div class="w-3 h-3 rounded-full bg-[#ffbd2e] transition-transform duration-200 group-hover/chrome:scale-125 group-hover/chrome:shadow-[0_0_6px_#ffbd2e]"></div>
      <div class="w-3 h-3 rounded-full bg-[#27c93f] transition-transform duration-200 group-hover/chrome:scale-125 group-hover/chrome:shadow-[0_0_6px_#27c93f]"></div>
    </div>
    <div class="text-xs text-surface-600 dark:text-primary-300/70 font-bold select-none">
      {title}
    </div>
    <div class="w-12"></div> <!-- spacer to center title -->
  </div>
  
  <!-- Terminal Content -->
  <div class="p-4 sm:p-6 overflow-x-auto">
    <slot />
  </div>
</div>
