---
interface Props {
  title?: string;
  id?: string;
}

const { title = 'bash', id } = Astro.props;
---

<div class="max-w-4xl mx-auto w-full mb-12 shadow-2xl rounded-lg overflow-hidden border border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-terminal-bg" {id}>
  <!-- Window Chrome -->
  <div class="bg-surface-200 dark:bg-[#1a2e28] px-4 py-2 flex items-center justify-between border-b border-surface-300 dark:border-[#2a3e38]">
    <div class="flex space-x-2">
      <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
      <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
      <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
    </div>
    <div class="text-xs text-surface-600 dark:text-primary-300/70 font-bold select-none">
      {title}
    </div>
    <div class="w-12"></div> <!-- spacer to center title -->
  </div>
  
  <!-- Terminal Content -->
  <div class="p-4 sm:p-6 overflow-x-auto">
    <slot />
  </div>
</div>
