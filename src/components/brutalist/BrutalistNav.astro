---
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const langSwitchHref = lang === 'en' ? '/brutalist/es/' : '/brutalist/';
const langSwitchLabel = lang === 'en' ? 'ES' : 'EN';

const navItems = [
  { href: '#about', label: t('nav.about') },
  { href: '#experience', label: t('nav.experience') },
  { href: '#projects', label: t('nav.projects') },
  { href: '#skills', label: t('nav.skills') },
  { href: '#contact', label: t('nav.contact') },
];
---

<nav class="relative z-50 bg-surface-50 dark:bg-terminal-bg border-b-3 border-surface-900 dark:border-terminal-border" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 sm:h-16">
      <a href={lang === 'en' ? '/brutalist/' : '/brutalist/es/'} class="font-display font-bold text-lg sm:text-xl uppercase tracking-tight text-surface-900 dark:text-terminal-fg hover:text-accent-500 dark:hover:text-accent-400" style="transition: none;">
        BQ
      </a>

      <div class="hidden md:flex items-center gap-0">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="font-display text-xs uppercase tracking-widest font-bold px-4 py-2 text-surface-900 dark:text-terminal-fg border-l-3 border-surface-900 dark:border-terminal-border hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg"
            style="transition: none;"
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-0">
        <button
          id="theme-toggle"
          class="w-11 h-11 sm:w-12 sm:h-12 flex items-center justify-center border-3 border-surface-900 dark:border-terminal-border text-surface-900 dark:text-terminal-fg bg-surface-50 dark:bg-terminal-bg hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg font-display font-bold text-xs uppercase"
          aria-label={lang === 'en' ? 'Toggle dark mode' : 'Cambiar modo oscuro'}
          style="transition: none;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="square" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
        </button>

        <a
          href={langSwitchHref}
          class="w-11 h-11 sm:w-12 sm:h-12 flex items-center justify-center border-3 border-l-0 border-surface-900 dark:border-terminal-border text-surface-900 dark:text-terminal-fg bg-surface-50 dark:bg-terminal-bg hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg font-display font-bold text-xs uppercase"
          aria-label={lang === 'en' ? 'ES — Switch to Spanish' : 'EN — Cambiar a inglés'}
          style="transition: none;"
        >
          {langSwitchLabel}
        </a>

        <button
          id="mobile-menu-toggle"
          class="w-11 h-11 sm:w-12 sm:h-12 flex md:hidden items-center justify-center border-3 border-l-0 border-surface-900 dark:border-terminal-border text-surface-900 dark:text-terminal-fg bg-surface-50 dark:bg-terminal-bg hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg"
          aria-label={lang === 'en' ? 'Open menu' : 'Abrir menú'}
          style="transition: none;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t-3 border-surface-900 dark:border-terminal-border">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="mobile-nav-link block font-display text-sm uppercase tracking-widest font-bold px-6 py-4 text-surface-900 dark:text-terminal-fg border-b-3 border-surface-900 dark:border-terminal-border hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg"
        style="transition: none;"
      >
        {item.label}
      </a>
    ))}
  </div>
</nav>

<script is:inline>
(function() {
  var toggle = document.getElementById('mobile-menu-toggle');
  var menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', function() {
      menu.classList.toggle('hidden');
    });
    menu.querySelectorAll('.mobile-nav-link').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
      });
    });
  }
})();
</script>
