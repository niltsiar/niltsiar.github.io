---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

{profile.projects?.length > 0 && (
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-24">
    <!-- Section header -->
    <div class="border-b-3 border-surface-900 dark:border-terminal-border pb-4 mb-8 sm:mb-12">
      <span class="font-display text-xs uppercase tracking-widest font-bold text-primary-600 dark:text-primary-400">{t('projects.label')}</span>
      <h2 class="font-display font-bold uppercase tracking-tight text-surface-900 dark:text-terminal-fg mt-1" style="font-size: clamp(2.5rem, 6vw, 6rem);">
        {t('projects.title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-3 border-surface-900 dark:border-terminal-border">
      {profile.projects.map((project: any, index: number) => (
        <div class={`p-6 sm:p-8 flex flex-col ${index % 2 === 0 ? 'md:border-r-3 md:border-surface-900 md:dark:border-terminal-border' : ''} ${index < profile.projects.length - 2 ? 'border-b-3 border-surface-900 dark:border-terminal-border' : index < profile.projects.length - 1 ? 'border-b-3 md:border-b-0 border-surface-900 dark:border-terminal-border' : ''}`}>
          <div class="flex items-baseline justify-between gap-4 mb-3">
            <h3 class="font-display text-lg sm:text-xl font-bold uppercase text-surface-900 dark:text-terminal-fg truncate">
              {project.name}
            </h3>
            <span class="font-display text-xs uppercase tracking-widest text-surface-500 dark:text-surface-400 shrink-0">{project.period}</span>
          </div>

          <p class="text-sm text-surface-700 dark:text-surface-400 leading-relaxed flex-1">
            {project.description[lang]}
          </p>

          <div class="mt-4 flex flex-wrap gap-2">
            {project.skills.map((skill: string) => (
              <span class="font-display text-xs uppercase tracking-widest font-bold px-2 py-1 border-2 border-surface-400 dark:border-terminal-border text-surface-600 dark:text-surface-400">
                {skill}
              </span>
            ))}
          </div>

          {project.url && (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-2 font-display text-xs uppercase tracking-widest font-bold text-accent-500 dark:text-accent-400 hover:text-surface-900 dark:hover:text-terminal-fg border-b-2 border-accent-500 dark:border-accent-400 self-start"
              style="transition: none;"
            >
              {t('projects.view')}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="square" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
)}
