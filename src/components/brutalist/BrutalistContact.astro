---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-24">
  <!-- Section header -->
  <div class="border-b-3 border-surface-900 dark:border-terminal-border pb-4 mb-8 sm:mb-12">
    <span class="font-display text-xs uppercase tracking-widest font-bold text-accent-500 dark:text-accent-400">{t('contact.label')}</span>
    <h2 class="font-display font-bold uppercase tracking-tight text-surface-900 dark:text-terminal-fg mt-1" style="font-size: clamp(2.5rem, 6vw, 6rem);">
      {t('contact.title')}
    </h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 border-3 border-surface-900 dark:border-terminal-border">
    <!-- Email -->
    <div class="p-6 sm:p-8 border-b-3 sm:border-b-0 sm:border-r-3 border-surface-900 dark:border-terminal-border">
      <h3 class="font-display text-xs uppercase tracking-widest font-bold text-surface-500 dark:text-surface-400 mb-2">Email</h3>
      <div class="flex items-center gap-2">
        <a href={`mailto:${profile.email}`} class="font-display text-sm sm:text-base font-bold text-surface-900 dark:text-terminal-fg hover:text-accent-500 dark:hover:text-accent-400 break-all" style="transition: none;">
          {profile.email}
        </a>
        <button
          class="copy-btn w-11 h-11 shrink-0 flex items-center justify-center border-3 border-surface-900 dark:border-terminal-border text-surface-900 dark:text-terminal-fg hover:bg-surface-900 hover:text-surface-50 dark:hover:bg-terminal-fg dark:hover:text-terminal-bg"
          data-copy={profile.email}
          aria-label={lang === 'en' ? 'Copy email' : 'Copiar email'}
          style="transition: none;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- LinkedIn -->
    <div class="p-6 sm:p-8 border-b-3 border-surface-900 dark:border-terminal-border">
      <h3 class="font-display text-xs uppercase tracking-widest font-bold text-surface-500 dark:text-surface-400 mb-2">LinkedIn</h3>
      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="font-display text-sm sm:text-base font-bold text-surface-900 dark:text-terminal-fg hover:text-accent-500 dark:hover:text-accent-400 inline-flex items-center gap-2"
        style="transition: none;"
      >
        {profile.linkedin.replace('https://', '')}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="square" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>

    <!-- GitHub -->
    <div class="p-6 sm:p-8 border-b-3 sm:border-b-0 sm:border-r-3 border-surface-900 dark:border-terminal-border">
      <h3 class="font-display text-xs uppercase tracking-widest font-bold text-surface-500 dark:text-surface-400 mb-2">GitHub</h3>
      <a
        href={profile.github.url}
        target="_blank"
        rel="noopener noreferrer"
        class="font-display text-sm sm:text-base font-bold text-surface-900 dark:text-terminal-fg hover:text-accent-500 dark:hover:text-accent-400 inline-flex items-center gap-2"
        style="transition: none;"
      >
        {profile.github.url.replace('https://', '')}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="square" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>

    <!-- Mastodon -->
    <div class="p-6 sm:p-8">
      <h3 class="font-display text-xs uppercase tracking-widest font-bold text-surface-500 dark:text-surface-400 mb-2">Mastodon</h3>
      <a
        href={profile.mastodon}
        target="_blank"
        rel="noopener noreferrer"
        class="font-display text-sm sm:text-base font-bold text-surface-900 dark:text-terminal-fg hover:text-accent-500 dark:hover:text-accent-400 inline-flex items-center gap-2"
        style="transition: none;"
      >
        {profile.mastodon.replace('https://', '')}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="square" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>
  </div>
</div>
