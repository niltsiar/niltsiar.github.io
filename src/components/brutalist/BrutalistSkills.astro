---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const categoryLabels: Record<string, Record<string, string>> = {
  main: { en: 'Core', es: 'Principal' },
  mobile: { en: 'Mobile', es: 'Móvil' },
  architecture: { en: 'Architecture', es: 'Arquitectura' },
  tools: { en: 'Tools', es: 'Herramientas' },
};

const skillEntries = Object.entries(profile.skills) as [string, string[]][];
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-24">
  <!-- Section header -->
  <div class="border-b-3 border-surface-900 dark:border-terminal-border pb-4 mb-8 sm:mb-12">
    <span class="font-display text-xs uppercase tracking-widest font-bold text-accent-500 dark:text-accent-400">{t('skills.label')}</span>
    <h2 class="font-display font-bold uppercase tracking-tight text-surface-900 dark:text-terminal-fg mt-1" style="font-size: clamp(2.5rem, 6vw, 6rem);">
      {t('skills.title')}
    </h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0 border-3 border-surface-900 dark:border-terminal-border">
    {skillEntries.map(([category, skills], index) => (
      <div class={`p-6 sm:p-8 ${index < skillEntries.length - 1 ? 'border-b-3 sm:border-b-0 sm:border-r-3 border-surface-900 dark:border-terminal-border' : ''}`}>
        <h3 class="font-display text-xs uppercase tracking-widest font-bold text-accent-500 dark:text-accent-400 mb-4 pb-2 border-b-2 border-surface-300 dark:border-terminal-border">
          {categoryLabels[category]?.[lang] || category}
        </h3>
        <ul class="space-y-3">
          {skills.map((skill: string) => (
            <li class="font-display text-sm sm:text-base font-bold uppercase tracking-wide text-surface-900 dark:text-terminal-fg">
              {skill}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
