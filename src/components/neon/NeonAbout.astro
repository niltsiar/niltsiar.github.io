---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-5xl mx-auto px-4 sm:px-6">
  <!-- Section header -->
  <div class="mb-12">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('about.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {profile.aboutTitle[lang]}
    </h2>
  </div>

  <!-- Bio panel — full width on top -->
  <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm overflow-hidden mb-6">
    <!-- Window title bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
      <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
      <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">about.md</span>
    </div>
    <!-- Content -->
    <div class="p-5 sm:p-6">
      <p class="text-base leading-relaxed text-surface-700 dark:text-surface-300">
        {profile.bio[lang]}
      </p>
    </div>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <!-- Experience stat -->
    <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm p-5 text-center">
      <div class="font-display font-bold text-3xl text-primary-600 dark:text-primary-400 [text-shadow:0_0_10px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] dark:[text-shadow:0_0_15px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)] animate-[glow_2s_ease-in-out_infinite_alternate]">17+</div>
      <div class="text-sm text-surface-500 dark:text-surface-400 mt-1">{t('about.stats.experience')}</div>
    </div>

    <!-- Repos stat -->
    <a href={profile.github.url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm p-5 text-center hover:border-primary-500/50 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_15%,transparent)] transition-all duration-300 group" aria-label={`${profile.github.publicRepos} ${t('about.stats.repos')}`}>
      <div class="font-display font-bold text-3xl text-primary-600 dark:text-primary-400 [text-shadow:0_0_10px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] dark:[text-shadow:0_0_15px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)] animate-[glow_2s_ease-in-out_infinite_alternate]">{profile.github.publicRepos}</div>
      <div class="text-sm text-surface-500 dark:text-surface-400 mt-1">{t('about.stats.repos')}</div>
    </a>

    <!-- Followers stat -->
    <a href={profile.github.url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm p-5 text-center hover:border-primary-500/50 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_15%,transparent)] transition-all duration-300 group" aria-label={`${profile.github.followers} ${t('about.stats.followers')}`}>
      <div class="font-display font-bold text-3xl text-primary-600 dark:text-primary-400 [text-shadow:0_0_10px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] dark:[text-shadow:0_0_15px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)] animate-[glow_2s_ease-in-out_infinite_alternate]">{profile.github.followers}</div>
      <div class="text-sm text-surface-500 dark:text-surface-400 mt-1">{t('about.stats.followers')}</div>
    </a>
  </div>

  <!-- Info panels grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <!-- Education panel -->
    {profile.education.length > 0 && (
      <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
          <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
          <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">education.log</span>
        </div>
        <div class="p-5 sm:p-6 space-y-3">
          {profile.education.map((edu: any) => (
            <div>
              <div class="font-display font-semibold text-sm text-surface-800 dark:text-surface-200">{edu.degree[lang]}</div>
              <div class="text-sm text-surface-500 dark:text-surface-400">{edu.institution}</div>
              <div class="text-xs text-surface-400 dark:text-surface-500">{edu.period}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Certifications panel -->
    {profile.certifications.length > 0 && (
      <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
          <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
          <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">certs.log</span>
        </div>
        <div class="p-5 sm:p-6">
          <div class="space-y-2">
            {profile.certifications.map((cert: any) => (
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-sm text-surface-700 dark:text-surface-300 truncate">{cert.name}</span>
                <span class="text-xs text-surface-400 dark:text-surface-500 shrink-0">{cert.date}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Languages panel -->
    {profile.languages.length > 0 && (
      <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/50 backdrop-blur-sm overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
          <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
          <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">languages.cfg</span>
        </div>
        <div class="p-5 sm:p-6 space-y-2">
          {profile.languages.map((lng: any) => (
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-surface-700 dark:text-surface-300">{lng.name[lang]}</span>
              <span class="text-xs px-2 py-0.5 rounded-full border border-primary-500/30 text-primary-600 dark:text-primary-400 bg-primary-500/5">{lng.level[lang]}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</div>
