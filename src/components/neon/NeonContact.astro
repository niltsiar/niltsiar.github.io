---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-3xl mx-auto px-4 sm:px-6">
  <!-- Section header -->
  <div class="mb-12 text-center">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('contact.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {t('contact.title')}
    </h2>
  </div>

  <!-- Contact links — OS window panel -->
  <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm overflow-hidden">
    <!-- Window bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
      <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
      <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">contact.sh</span>
    </div>

    <div class="p-5 sm:p-6 space-y-4">
      <!-- Email -->
      <div class="flex items-center justify-between gap-3 p-3 rounded-lg border border-surface-200/60 dark:border-terminal-border/60 bg-surface-100/40 dark:bg-terminal-bg/40 hover:border-primary-500/30 dark:hover:border-primary-500/40 transition-colors group">
        <div class="flex items-center gap-3 min-w-0">
          <svg class="w-5 h-5 text-primary-500 dark:text-primary-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <a href={`mailto:${profile.email}`} class="text-sm text-surface-700 dark:text-surface-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors truncate">
            {profile.email}
          </a>
        </div>
        <button class="copy-btn shrink-0 w-11 h-11 flex items-center justify-center rounded-lg border border-surface-300/50 dark:border-terminal-border text-surface-500 dark:text-surface-400 hover:text-primary-500 dark:hover:text-primary-400 hover:border-primary-500/50 hover:shadow-[0_0_8px_color-mix(in_srgb,var(--color-primary-500)_20%,transparent)] transition-all" data-copy={profile.email} aria-label={lang === 'en' ? 'Copy email' : 'Copiar email'}>
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
          </svg>
        </button>
      </div>

      <!-- LinkedIn -->
      <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-surface-200/60 dark:border-terminal-border/60 bg-surface-100/40 dark:bg-terminal-bg/40 hover:border-primary-500/30 dark:hover:border-primary-500/40 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] transition-all duration-300 group" aria-label="LinkedIn profile">
        <svg class="w-5 h-5 text-primary-500 dark:text-primary-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span class="text-sm text-surface-700 dark:text-surface-300 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">LinkedIn</span>
        <svg class="w-4 h-4 ml-auto text-surface-400 dark:text-surface-500 group-hover:text-primary-500 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>

      <!-- GitHub -->
      <a href={profile.github.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-surface-200/60 dark:border-terminal-border/60 bg-surface-100/40 dark:bg-terminal-bg/40 hover:border-primary-500/30 dark:hover:border-primary-500/40 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] transition-all duration-300 group" aria-label="GitHub profile">
        <svg class="w-5 h-5 text-primary-500 dark:text-primary-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        <span class="text-sm text-surface-700 dark:text-surface-300 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">GitHub</span>
        <svg class="w-4 h-4 ml-auto text-surface-400 dark:text-surface-500 group-hover:text-primary-500 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>

      <!-- Mastodon -->
      <a href={profile.mastodon} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-surface-200/60 dark:border-terminal-border/60 bg-surface-100/40 dark:bg-terminal-bg/40 hover:border-primary-500/30 dark:hover:border-primary-500/40 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] transition-all duration-300 group" aria-label="Mastodon profile">
        <svg class="w-5 h-5 text-primary-500 dark:text-primary-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 00.023-.043v-1.809a.052.052 0 00-.02-.041.053.053 0 00-.046-.01 20.282 20.282 0 01-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 01-.319-1.433.053.053 0 01.066-.054 19.648 19.648 0 004.636.546c.568 0 1.135-.007 1.7-.028 1.748-.065 3.581-.19 5.302-.614 2.082-.513 3.898-2.108 4.093-6.138.077-1.564.074-3.023.074-4.474 0-.703.049-1.44-.019-2.168z"/>
        </svg>
        <span class="text-sm text-surface-700 dark:text-surface-300 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Mastodon</span>
        <svg class="w-4 h-4 ml-auto text-surface-400 dark:text-surface-500 group-hover:text-primary-500 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>
</div>
