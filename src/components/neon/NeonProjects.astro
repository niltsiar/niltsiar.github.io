---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-5xl mx-auto px-4 sm:px-6">
  <!-- Section header -->
  <div class="mb-12">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('projects.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {t('projects.title')}
    </h2>
  </div>

  <!-- Projects grid -->
  {profile.projects?.length > 0 && (
  <div class="grid sm:grid-cols-2 gap-5">
    {profile.projects.map((project: any) => (
      <a
        href={project.url_es && lang === 'es' ? project.url_es : project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm overflow-hidden hover:border-primary-500/50 dark:hover:border-primary-500/50 hover:shadow-[0_0_20px_color-mix(in_srgb,var(--color-primary-500)_15%,transparent)] dark:hover:shadow-[0_0_25px_color-mix(in_srgb,var(--color-primary-500)_35%,transparent)] transition-all duration-300"
        aria-label={`${project.name} — ${t('projects.view')}`}
      >
        <!-- Ambient glow on hover -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,var(--color-primary-500)_0%,transparent_60%)] opacity-0 group-hover:opacity-[0.06] dark:group-hover:opacity-[0.15] transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>

        <div class="relative p-5 sm:p-6">
          <!-- Header row -->
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="font-display font-semibold text-lg text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {project.name}
            </h3>
            <!-- External link icon -->
            <svg class="w-4 h-4 text-surface-400 dark:text-surface-500 group-hover:text-primary-500 dark:group-hover:text-primary-400 shrink-0 mt-1 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </div>

          <!-- Period -->
          <div class="text-xs text-surface-400 dark:text-surface-500 mb-3">{project.period}</div>

          <!-- Description -->
          <p class="text-sm leading-relaxed text-surface-600 dark:text-surface-400 mb-4">
            {project.description[lang]}
          </p>

          <!-- Skills -->
          <div class="flex flex-wrap gap-1.5">
            {project.skills.map((skill: string) => (
              <span class="px-2 py-0.5 text-xs rounded-full border border-primary-500/25 dark:border-primary-500/30 text-primary-600 dark:text-primary-400 bg-primary-500/5 dark:bg-primary-500/10">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>
  )}
</div>
