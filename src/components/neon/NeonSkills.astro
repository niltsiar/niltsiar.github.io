---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const categoryLabels: Record<string, Record<string, string>> = {
  main: { en: 'Core', es: 'Principal' },
  mobile: { en: 'Mobile', es: 'Móvil' },
  backend: { en: 'Backend', es: 'Backend' },
  architecture: { en: 'Architecture', es: 'Arquitectura' },
  tools: { en: 'Tooling', es: 'Herramientas' },
};
---

<div class="max-w-5xl mx-auto px-4 sm:px-6">
  <!-- Section header -->
  <div class="mb-12">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('skills.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {t('skills.title')}
    </h2>
  </div>

  <!-- Skills categories -->
  <div class="grid sm:grid-cols-2 gap-5">
    {Object.entries(profile.skills).map(([category, skills]) => (
      <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm overflow-hidden hover:border-primary-500/30 dark:hover:border-primary-500/40 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:hover:shadow-[0_0_18px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] transition-all duration-300">
        <!-- Window bar -->
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
          <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
          <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">
            {categoryLabels[category]?.[lang] ?? category}
          </span>
        </div>

        <div class="p-5 sm:p-6">
          <div class="flex flex-wrap gap-2">
            {(skills as string[]).map((skill: string) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-full border border-primary-500/30 dark:border-primary-500/40 text-primary-700 dark:text-primary-300 bg-primary-500/5 dark:bg-primary-500/10 hover:bg-primary-500/15 dark:hover:bg-primary-500/20 hover:shadow-[0_0_8px_color-mix(in_srgb,var(--color-primary-500)_20%,transparent)] dark:hover:shadow-[0_0_12px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)] transition-all duration-200">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-400 dark:bg-primary-500 opacity-60" aria-hidden="true"></span>
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
