---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-5xl mx-auto px-4 sm:px-6">
  <!-- Section header -->
  <div class="mb-12">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('experience.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {t('experience.title')}
    </h2>
  </div>

  <!-- Timeline -->
  {profile.experience?.length > 0 && (
  <div class="relative">
    <!-- Vertical neon line -->
    <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-surface-200 dark:bg-terminal-border" aria-hidden="true">
      <div class="absolute inset-0 bg-primary-500/30 dark:bg-primary-500/60 shadow-[0_0_6px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] dark:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)]"></div>
    </div>

    <div class="space-y-8">
      {profile.experience.map((exp: any, i: number) => (
        <div class="relative pl-12 sm:pl-16">
          <!-- Timeline node -->
          <div class="absolute left-2.5 sm:left-4.5 top-6 w-3 h-3 rounded-full border-2 border-primary-500 dark:border-primary-400 bg-surface-50 dark:bg-terminal-bg shadow-[0_0_8px_color-mix(in_srgb,var(--color-primary-500)_50%,transparent)] dark:shadow-[0_0_12px_color-mix(in_srgb,var(--color-primary-500)_70%,transparent)]" aria-hidden="true">
            {exp.current && (
              <div class="absolute -inset-1 rounded-full bg-primary-500/20 animate-[glow_2s_ease-in-out_infinite_alternate]"></div>
            )}
          </div>

          <!-- Experience card — OS window style -->
          <div class="rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm overflow-hidden hover:border-primary-500/30 dark:hover:border-primary-500/40 hover:shadow-[0_0_15px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:hover:shadow-[0_0_20px_color-mix(in_srgb,var(--color-primary-500)_25%,transparent)] transition-all duration-300">
            <!-- Window bar -->
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-200/60 dark:border-terminal-border bg-surface-100/60 dark:bg-terminal-bg/60">
              <span class="w-3 h-3 rounded-full bg-primary-400/60 dark:bg-primary-500/60" aria-hidden="true"></span>
              <span class="w-3 h-3 rounded-full bg-accent-400/60 dark:bg-accent-500/60" aria-hidden="true"></span>
              <span class="w-3 h-3 rounded-full bg-surface-400/40 dark:bg-surface-600/40" aria-hidden="true"></span>
              <span class="ml-2 text-xs font-display text-surface-400 dark:text-surface-500">{exp.company.toLowerCase()}.exp</span>
            </div>

            <div class="p-5 sm:p-6">
              <!-- Role & meta -->
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <h3 class="font-display font-semibold text-lg text-surface-900 dark:text-surface-100">
                    {exp.role[lang]}
                  </h3>
                  <div class="text-sm text-primary-600 dark:text-primary-400 font-medium truncate">{exp.company}</div>
                </div>
                <div class="text-right shrink-0">
                  <div class="text-sm text-surface-500 dark:text-surface-400">{exp.period}</div>
                  <div class="text-xs text-surface-400 dark:text-surface-500">{exp.duration[lang]}</div>
                </div>
              </div>

              <!-- Current badge -->
              {exp.current && (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium border border-primary-500/40 text-primary-600 dark:text-primary-400 bg-primary-500/10 mb-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary-400 animate-[glow_2s_ease-in-out_infinite_alternate]" aria-hidden="true"></span>
                  {t('experience.current')}
                </span>
              )}

              <!-- Description -->
              {exp.description && (
                <p class="text-sm leading-relaxed text-surface-600 dark:text-surface-400">
                  {exp.description[lang]}
                </p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  )}
</div>
