---
import profile from '../../content/profile.json';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

{(profile.podcast?.length > 0 || profile.community?.length > 0) && (
<div class="max-w-4xl mx-auto px-4 sm:px-6">
  <div class="mb-12">
    <span class="font-display text-xs font-semibold uppercase tracking-widest text-primary-500 dark:text-primary-400 mb-2 block">{t('community.label')}</span>
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-surface-900 dark:text-surface-50 [text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:[text-shadow:0_0_30px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)]">
      {t('community.title')}
    </h2>
  </div>

  {profile.podcast?.length > 0 && (
  <div class="mb-8">
    <h3 class="text-xs uppercase tracking-widest font-semibold text-primary-500 dark:text-primary-400 mb-4">
      {t('community.podcast')}
    </h3>
    <div class="space-y-4">
      {profile.podcast.map((episode: any) => (
        <a
          href={episode.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-4 rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm hover:border-primary-500/40 dark:hover:border-primary-500/40 hover:shadow-[0_0_12px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:hover:shadow-[0_0_18px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] transition-all duration-300"
          aria-label={episode.title[lang]}
        >
          <div class="w-10 h-10 rounded-lg bg-primary-500/10 dark:bg-primary-500/20 border border-primary-500/20 dark:border-primary-500/30 flex items-center justify-center shrink-0 group-hover:shadow-[0_0_8px_color-mix(in_srgb,var(--color-primary-500)_20%,transparent)] dark:group-hover:shadow-[0_0_14px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)] transition-shadow">
            <svg class="w-5 h-5 text-primary-500 dark:text-primary-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <h4 class="font-display font-semibold text-sm text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {episode.title[lang]}
            </h4>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-primary-600 dark:text-primary-400">{episode.show}</span>
              <span class="text-xs text-surface-400 dark:text-surface-500">&middot;</span>
              <span class="text-xs text-surface-400 dark:text-surface-500">{episode.date}</span>
            </div>
          </div>

          <svg class="w-4 h-4 text-surface-400 dark:text-surface-500 group-hover:text-primary-500 dark:group-hover:text-primary-400 shrink-0 mt-1 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      ))}
    </div>
  </div>
  )}

  {profile.community?.length > 0 && (
  <div>
    <h3 class="text-xs uppercase tracking-widest font-semibold text-surface-500 dark:text-surface-400 mb-4">
      {t('community.also')}
    </h3>
    <div class="space-y-4">
      {profile.community.map((item: any) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-4 rounded-xl border border-surface-200/80 dark:border-terminal-border bg-surface-50/80 dark:bg-terminal-header/40 backdrop-blur-sm hover:border-primary-500/40 dark:hover:border-primary-500/40 hover:shadow-[0_0_12px_color-mix(in_srgb,var(--color-primary-500)_10%,transparent)] dark:hover:shadow-[0_0_18px_color-mix(in_srgb,var(--color-primary-500)_30%,transparent)] transition-all duration-300"
          aria-label={item.title[lang]}
        >
          <div class="w-10 h-10 rounded-lg bg-accent-500/10 dark:bg-accent-500/20 border border-accent-500/20 dark:border-accent-500/30 flex items-center justify-center shrink-0 group-hover:shadow-[0_0_8px_color-mix(in_srgb,var(--color-accent-500)_20%,transparent)] dark:group-hover:shadow-[0_0_14px_color-mix(in_srgb,var(--color-accent-500)_40%,transparent)] transition-shadow">
            <svg class="w-5 h-5 text-accent-500 dark:text-accent-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <h4 class="font-display font-semibold text-sm text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {item.title[lang]}
            </h4>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-accent-600 dark:text-accent-400">{item.platform}</span>
            </div>
          </div>

          <svg class="w-4 h-4 text-surface-400 dark:text-surface-500 group-hover:text-primary-500 dark:group-hover:text-primary-400 shrink-0 mt-1 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      ))}
    </div>
  </div>
  )}
</div>
)}
