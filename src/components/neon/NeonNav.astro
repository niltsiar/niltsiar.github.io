---
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: '#about', label: t('nav.about') },
  { href: '#experience', label: t('nav.experience') },
  { href: '#projects', label: t('nav.projects') },
  { href: '#skills', label: t('nav.skills') },
  { href: '#contact', label: t('nav.contact') },
];

const langSwitchHref = lang === 'en' ? '/es/' : '/';
const langSwitchLabel = lang === 'en' ? 'ES' : 'EN';
---

<nav class="relative z-40 bg-surface-100 dark:bg-terminal-bg border-b border-surface-300/50 dark:border-terminal-border" aria-label="Main navigation">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Home -->
      <a href={lang === 'en' ? '/' : '/es/'} class="font-display font-bold text-lg text-primary-600 dark:text-primary-400 [text-shadow:0_0_8px_color-mix(in_srgb,var(--color-primary-500)_40%,transparent)] dark:[text-shadow:0_0_12px_color-mix(in_srgb,var(--color-primary-500)_60%,transparent)] hover:[text-shadow:0_0_16px_color-mix(in_srgb,var(--color-primary-400)_60%,transparent)] dark:hover:[text-shadow:0_0_20px_color-mix(in_srgb,var(--color-primary-400)_80%,transparent)] transition-all duration-300" >
        BQ<span class="inline-block w-[2px] h-[1em] bg-primary-500 dark:bg-primary-400 ml-0.5 animate-[blink_1s_steps(2,start)_infinite] align-middle" aria-hidden="true"></span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="relative px-3 py-2 text-sm font-medium text-surface-600 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 rounded-full hover:bg-primary-500/10 dark:hover:bg-primary-500/10 group"
          >
            {link.label}
            <span class="absolute bottom-0.5 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-500 shadow-[0_0_6px_color-mix(in_srgb,var(--color-primary-500)_80%,transparent)] group-hover:w-3/4 transition-all duration-300" aria-hidden="true"></span>
          </a>
        ))}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="w-11 h-11 flex items-center justify-center rounded-full border border-surface-300 dark:border-terminal-border text-surface-600 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400 hover:border-primary-500/50 dark:hover:border-primary-500/50 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_20%,transparent)] transition-all duration-300"
          aria-label={lang === 'en' ? 'Toggle theme' : 'Cambiar tema'}
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-5 h-5 hidden dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-5 h-5 block dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>

        <!-- Language switcher -->
        <a
          href={langSwitchHref}
          class="px-3 py-1.5 text-sm font-display font-semibold rounded-full border border-primary-500/40 text-primary-600 dark:text-primary-400 hover:bg-primary-500/10 hover:shadow-[0_0_10px_color-mix(in_srgb,var(--color-primary-500)_20%,transparent)] transition-all duration-300"
          aria-label={lang === 'en' ? 'Cambiar a español' : 'Switch to English'}
        >
          {langSwitchLabel}
        </a>

        <!-- Mobile menu button -->
        <button
          id="neon-mobile-toggle"
          class="md:hidden w-11 h-11 flex items-center justify-center rounded-full border border-surface-300 dark:border-terminal-border text-surface-600 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          aria-label={lang === 'en' ? 'Open menu' : 'Abrir menú'}
          aria-expanded="false"
        >
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="neon-mobile-menu" class="md:hidden hidden pb-4 border-t border-surface-300/30 dark:border-terminal-border/30 mt-1">
      <div class="flex flex-col gap-1 pt-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="neon-mobile-link px-4 py-2.5 text-sm font-medium text-surface-600 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-500/10 rounded-lg transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script is:inline>
(function() {
  var toggle = document.getElementById('neon-mobile-toggle');
  var menu = document.getElementById('neon-mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
    menu.querySelectorAll('.neon-mobile-link').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
})();
</script>
