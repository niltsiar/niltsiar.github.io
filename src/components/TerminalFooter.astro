---
import { useTranslations } from '../i18n/translations';
import Prompt from './Prompt.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="mt-16 w-full pt-8 pb-4 border-t-2 border-surface-200 dark:border-terminal-border text-xs sm:text-sm text-surface-500 dark:text-surface-400">
  <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-2">
      <Prompt path="~" />
      <span class="text-surface-400 dark:text-surface-400">logout</span>
    </div>
    
    <div class="text-center md:text-right">
      <span>{t('footer.made')} <span class="text-orange-500">🧡</span> {t('footer.and')} <a href="https://webreactiva.com" class="text-primary-600 dark:text-primary-400 underline hover:no-underline">Web Reactiva</a></span>
      <span class="block mt-1 text-surface-400 dark:text-surface-400">© {new Date().getFullYear()} {t('footer.rights')}</span>
    </div>
  </div>
</footer>
