---
import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="mt-4 font-mono text-sm sm:text-base border border-surface-200 dark:border-terminal-border p-4 bg-surface-100 dark:bg-terminal-bg shadow-sm overflow-x-auto whitespace-pre-wrap break-words">
  <div class="mb-4 pb-2 border-b border-surface-300 dark:border-terminal-dim">
    <span class="text-surface-600 dark:text-surface-300 font-bold">--- {t('community.podcast').toLowerCase()}.log ---</span>
  </div>
  {profile.podcast.length > 0 ? (
    <ul class="space-y-4 list-none text-surface-800 dark:text-surface-300">
      {profile.podcast.map(ep => (
        <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between group">
          <div class="flex items-baseline space-x-2">
            <span class="text-primary-600 dark:text-accent-400 font-bold">*</span>
            <a href={ep.url} target="_blank" rel="noopener noreferrer" class="hover:underline font-bold text-surface-900 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">
              {ep.title[lang]}
            </a>
          </div>
          <div class="text-xs sm:text-sm text-surface-500 dark:text-surface-300 mt-1 sm:mt-0 flex-shrink-0">
            [{ep.show}] - {ep.date}
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-surface-500 dark:text-surface-400 italic">// No podcast episodes found</p>
  )}

  {profile.community?.length > 0 && (
    <div class="mt-6 pt-4 border-t border-surface-300 dark:border-terminal-dim">
      <div class="mb-3">
        <span class="text-surface-500 dark:text-surface-400 text-xs uppercase tracking-wider"># {t('community.also')}</span>
      </div>
      <ul class="space-y-3 list-none text-surface-800 dark:text-surface-300">
        {profile.community.map(item => (
          <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between group">
            <div class="flex items-baseline space-x-2">
              <span class="text-accent-500 dark:text-accent-400 font-bold">→</span>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="hover:underline font-bold text-surface-900 dark:text-primary-300 group-hover:text-primary-600 dark:group-hover:text-white transition-colors">
                {item.title[lang]}
              </a>
            </div>
            <div class="text-xs sm:text-sm text-surface-500 dark:text-surface-300 mt-1 sm:mt-0 flex-shrink-0">
              [{item.platform}]
            </div>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
