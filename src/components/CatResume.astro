---
import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="mt-4 border border-surface-200 dark:border-terminal-border p-4 bg-surface-100 dark:bg-[#0a0f0d] shadow-sm font-mono text-sm leading-relaxed overflow-x-auto whitespace-pre-wrap break-words">
  <div class="mb-4 pb-2 border-b border-surface-300 dark:border-terminal-dim">
    <span class="text-surface-600 dark:text-surface-400 font-bold">--- {t('about.label')} ---</span>
  </div>
  <p class="text-surface-800 dark:text-surface-300 mb-6">{profile.bio[lang]}</p>
  
  <div class="mb-4 pb-2 border-b border-surface-300 dark:border-terminal-dim">
    <span class="text-surface-600 dark:text-surface-400 font-bold">--- {lang === 'es' ? 'Educación' : 'Education'} ---</span>
  </div>
  <div class="text-surface-800 dark:text-surface-300 mb-6">
    {profile.education.map(edu => (
      <div class="mb-4 last:mb-0">
        <div class="font-bold text-primary-700 dark:text-primary-400">{edu.degree[lang]} | {edu.institution} ({edu.period})</div>
        {edu.thesis && <div class="mt-1"><span class="text-surface-500 dark:text-surface-400">{lang === 'es' ? 'Tesis:' : 'Thesis:'}</span> {edu.thesis[lang]}</div>}
        {edu.activities && <div class="mt-1"><span class="text-surface-500 dark:text-surface-400">{lang === 'es' ? 'Actividades:' : 'Activities:'}</span> {edu.activities[lang]}</div>}
      </div>
    ))}
  </div>

  <div class="mb-4 pb-2 border-b border-surface-300 dark:border-terminal-dim">
    <span class="text-surface-600 dark:text-surface-400 font-bold">--- {lang === 'es' ? 'Certificaciones' : 'Certifications'} ---</span>
  </div>
  <ul class="text-surface-800 dark:text-surface-300 mb-6 list-none space-y-1">
    {profile.certifications.map(cert => (
      <li><span class="text-primary-600 dark:text-accent-400 font-bold">*</span> {cert.name} - <span class="text-surface-500 dark:text-surface-400">{cert.issuer} ({cert.date})</span></li>
    ))}
  </ul>

  <div class="mb-4 pb-2 border-b border-surface-300 dark:border-terminal-dim">
    <span class="text-surface-600 dark:text-surface-400 font-bold">--- {lang === 'es' ? 'Idiomas' : 'Languages'} ---</span>
  </div>
  <ul class="text-surface-800 dark:text-surface-300 mb-6 list-none space-y-1">
    {profile.languages.map(langItem => (
      <li><span class="text-primary-600 dark:text-accent-400 font-bold">*</span> {langItem.name[lang]}: <span class="text-surface-500 dark:text-surface-400">{langItem.level[lang]}</span></li>
    ))}
  </ul>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 pt-4 border-t border-surface-300 dark:border-terminal-dim">
    <div>
      <div class="text-xs text-surface-500 dark:text-surface-300 uppercase tracking-wider mb-1">
        {t('about.stats.experience')}
      </div>
      <div class="text-2xl font-bold text-primary-600 dark:text-accent-400">17+</div>
    </div>
    
    <div>
      <div class="text-xs text-surface-500 dark:text-surface-300 uppercase tracking-wider mb-1">
        {t('about.stats.repos')}
      </div>
      <div class="text-2xl font-bold text-primary-600 dark:text-accent-400">
        <a href={profile.github.url} target="_blank" rel="noopener noreferrer" class="hover:underline">{profile.github.publicRepos}</a>
      </div>
    </div>
    
    <div>
      <div class="text-xs text-surface-500 dark:text-surface-300 uppercase tracking-wider mb-1">
        {t('about.stats.followers')}
      </div>
      <div class="text-2xl font-bold text-primary-600 dark:text-accent-400">
        <a href={profile.github.url} target="_blank" rel="noopener noreferrer" class="hover:underline">{profile.github.followers}</a>
      </div>
    </div>
  </div>
</div>
