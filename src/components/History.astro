---

import profile from '../content/profile.json';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
  type: 'experience' | 'projects';
}

const { lang, type } = Astro.props;
const t = useTranslations(lang);

function shortHash(name: string): string {
  let h = 0;
  for (let i = 0; i < name.length; i++) {
    h = ((h << 5) - h + name.charCodeAt(i)) | 0;
  }
  return Math.abs(h).toString(16).slice(0, 7).padStart(7, '0');
}
---

<div class="mt-4 font-mono text-sm sm:text-base border-l-2 border-surface-200 dark:border-terminal-dim pl-4 ml-2">
  {type === 'experience' && (profile.experience.length > 0 ? profile.experience.map((exp, index) => (
    <div class="relative mb-8 pb-4 border-b border-surface-200 dark:border-terminal-dim last:border-0 hover:bg-surface-100 dark:hover:bg-terminal-hover hover:shadow-md p-4 transition-all group">
      <!-- Timeline dot -->
      <div class="absolute -left-6 top-6 w-3 h-3 rounded-full border-2 border-surface-50 dark:border-terminal-bg bg-primary-500 dark:bg-accent-400 group-hover:bg-primary-600 dark:group-hover:bg-white transition-colors"></div>
      
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
        <h3 class="text-xl font-bold text-surface-900 dark:text-primary-300">
          {exp.role[lang]} 
          <span class="text-surface-500 dark:text-surface-400 font-normal">@ {exp.company}</span>
        </h3>
        <span class="text-xs sm:text-sm font-bold bg-surface-200 dark:bg-terminal-hover text-surface-600 dark:text-primary-400 border border-surface-300 dark:border-terminal-chrome px-2 py-1 rounded inline-block mt-2 sm:mt-0">
          {exp.period} | {exp.duration[lang]}
        </span>
      </div>
      
      <p class="text-surface-700 dark:text-surface-300 leading-relaxed mt-4">
        {exp.description[lang]}
      </p>
      
      {exp.current && (
        <span class="inline-block mt-4 text-xs font-bold bg-primary-100 dark:bg-primary-900/50 text-primary-700 dark:text-primary-400 border border-primary-300 dark:border-primary-700 px-3 py-1 rounded-full animate-float">
          * {t('experience.current')}
        </span>
      )}
    </div>
  )) : (
    <p class="text-surface-500 dark:text-surface-400 italic p-4">// No experience entries found</p>
  ))}

  {type === 'projects' && (profile.projects.length > 0 ? profile.projects.map((project, index) => (
    <div class="relative mb-8 pb-4 border-b border-surface-200 dark:border-terminal-dim last:border-0 hover:bg-surface-100 dark:hover:bg-terminal-hover hover:shadow-md p-4 transition-all group">
      <!-- Timeline dot -->
      <div class="absolute -left-6 top-6 w-3 h-3 rounded-full border-2 border-surface-50 dark:border-terminal-bg bg-primary-500 dark:bg-accent-400 group-hover:bg-primary-600 dark:group-hover:bg-white transition-colors"></div>
      
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
        <h3 class="text-xl font-bold text-surface-900 dark:text-primary-300">
          <span class="text-sm font-normal text-surface-400 dark:text-surface-500 mr-2 font-mono">{shortHash(project.name)}</span>
          {project.url ? <a href={project.url_es && lang === 'es' ? project.url_es : project.url} target="_blank" rel="noopener noreferrer" class="hover:underline">{project.name}</a> : project.name}
        </h3>
        <span class="text-xs sm:text-sm font-bold bg-surface-200 dark:bg-terminal-hover text-surface-600 dark:text-primary-400 border border-surface-300 dark:border-terminal-chrome px-2 py-1 rounded inline-block mt-2 sm:mt-0">
          {project.period}
        </span>
      </div>
      
      <p class="text-surface-700 dark:text-surface-300 leading-relaxed mt-4 mb-4">
        {project.description[lang]}
      </p>
      
      <div class="flex flex-wrap gap-2">
        {project.skills.map(skill => (
          <span class="text-xs font-bold bg-surface-200 dark:bg-terminal-hover text-surface-600 dark:text-primary-400 border border-surface-300 dark:border-terminal-chrome px-2 py-1 rounded">
            {skill}
          </span>
        ))}
      </div>
    </div>
  )) : (
    <p class="text-surface-500 dark:text-surface-400 italic p-4">// No projects found</p>
  ))}
</div>
