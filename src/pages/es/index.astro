---
/**
 * Dispatcher page (Spanish) — redirects to the correct design variant based on day of month.
 * Day % 6 maps to:
 *   0 → Terminal + Aston Martin (default)
 *   1 → Terminal + McLaren
 *   2 → Brutalist + Ferrari
 *   3 → Brutalist + Valladolid
 *   4 → Neon + Cyberpunk
 *   5 → Neon + Mercedes
 */
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Borja Quevedo - Portfolio</title>
    <script is:inline>
      (function() {
        var DESIGNS = [
          { path: '/terminal/es/', palette: 'aston-martin' },
          { path: '/terminal/es/', palette: 'mclaren' },
          { path: '/brutalist/es/', palette: 'ferrari' },
          { path: '/brutalist/es/', palette: 'valladolid' },
          { path: '/neon/es/', palette: 'cyberpunk' },
          { path: '/neon/es/', palette: 'mercedes' }
        ];

        var params = new URLSearchParams(window.location.search);
        var designParam = params.get('design');
        var paletteParam = params.get('palette');

        var variant;
        if (designParam !== null) {
          var idx = parseInt(designParam, 10);
          if (idx >= 0 && idx < DESIGNS.length) {
            variant = DESIGNS[idx];
          }
        }
        if (paletteParam && designParam !== null) {
          variant = variant || DESIGNS[0];
          variant = { path: variant.path, palette: paletteParam };
        }

        if (!variant) {
          var day = new Date().getDate() % 6;
          variant = DESIGNS[day];
        }

        localStorage.setItem('design-palette', variant.palette);
        localStorage.setItem('design-variant', JSON.stringify(variant));
        location.replace(variant.path);
      })();
    </script>
  </head>
  <body></body>
</html>
